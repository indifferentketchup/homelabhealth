#!/usr/bin/env bash
#
# hlh — manage the homelabhealth stack.
#
# Usage: hlh <command>
#
# Commands:
#   start     Start (or restart) the stack
#   stop      Stop the stack (preserves volumes + hlh_db)
#   restart   Full restart: stop then re-bootstrap
#   update    Pull latest images and recreate the stack
#   help      Show this help
#
# Those accustomed to the legacy individual launchers (hlhstart, hlhstop,
# hlhrestart, hlhupdate) may keep using them — they are wrappers that now
# delegate here.
#
set -euo pipefail

IMAGE="${HLH_ORCHESTRA_IMAGE:-ghcr.io/indifferentketchup/hlh_orchestra:latest}"

TTY_FLAGS=""
if [ -t 0 ] && [ -t 1 ]; then
  TTY_FLAGS="-it"
fi

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  start)
    echo "→ Starting homelabhealth…"
    exec docker run --rm $TTY_FLAGS \
      -v /var/run/docker.sock:/var/run/docker.sock \
      "$IMAGE"
    ;;

  stop)
    echo "→ Stopping homelabhealth app containers (keeping hlh_db)…"
    docker rm -f hlh_api hlh_ui hlh_swap hlh_search hlh_orchestra >/dev/null 2>&1 || true
    echo "✓ homelabhealth stopped."
    ;;

  restart)
    echo "→ Stopping homelabhealth app containers (keeping hlh_db)…"
    docker rm -f hlh_api hlh_ui hlh_swap hlh_search hlh_orchestra >/dev/null 2>&1 || true
    echo "→ Re-bootstrapping…"
    exec docker run --rm $TTY_FLAGS \
      -v /var/run/docker.sock:/var/run/docker.sock \
      "$IMAGE"
    ;;

  update)
    echo "→ Pulling latest bootstrap image…"
    docker pull "$IMAGE"
    echo "→ Removing app containers so they're recreated (hlh_db kept)…"
    docker rm -f hlh_api hlh_ui hlh_swap hlh_search >/dev/null 2>&1 || true
    echo "→ Bootstrapping (pulls remaining images, recreates stack)…"
    exec docker run --rm $TTY_FLAGS \
      -v /var/run/docker.sock:/var/run/docker.sock \
      "$IMAGE"
    ;;

  help|--help|-h)
    echo "Usage: hlh <command>"
    echo
    echo "Commands:"
    echo "  start     Start (or restart) the homelabhealth stack"
    echo "  stop      Stop the stack (keeps hlh_db + volumes intact)"
    echo "  restart   Full restart: stop then re-bootstrap"
    echo "  update    Pull latest images and recreate the stack"
    echo "  help      Show this help"
    ;;

  *)
    echo >&2 "hlh: unknown command '$CMD'"
    echo >&2 "Usage: hlh <command>"
    exit 1
    ;;
esac
