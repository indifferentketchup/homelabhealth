FROM debian:bookworm-slim

# Baseline shell + a dev-grade toolchain so terminals aren't a dead shell:
# git/python/node for the common case, the usual unix utilities, and
# build tools in case someone needs to compile something in a DAW repo.
RUN apt-get update && apt-get install -y --no-install-recommends \
    tmux openssh-client bash ca-certificates \
    git curl wget jq less file tree rsync unzip zip \
    vim nano sudo procps iproute2 man-db \
    python3 python3-pip python3-venv \
    nodejs npm \
    make build-essential \
    && rm -rf /var/lib/apt/lists/*

# UID/GID 1000 must match host samkintop. SSH refuses a key file (mode 0600)
# whose UID does not match the running user, with "UNPROTECTED PRIVATE KEY
# FILE!". Pin both explicitly — base-image defaults are not a contract.
RUN groupadd --gid 1000 agent \
 && useradd --uid 1000 --gid 1000 --create-home --shell /bin/bash agent \
 && echo 'agent ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/agent \
 && chmod 0440 /etc/sudoers.d/agent \
 && install -d -m 0700 -o agent -g agent /home/agent/.ssh
# Pre-create /home/agent/.ssh mode 0700 owned by agent. Docker bind-mounts
# do not reset directory mode/ownership of an existing parent; without this,
# a missing/wrong-mode parent breaks SSH at key-read time.

COPY tmux.conf /home/agent/.tmux.conf
RUN chown agent:agent /home/agent/.tmux.conf

COPY tmux-agent-entrypoint.sh /usr/local/bin/tmux-agent-entrypoint.sh
RUN chmod +x /usr/local/bin/tmux-agent-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/tmux-agent-entrypoint.sh"]
