# Copy to `.env` and adjust per machine. Compose loads this file automatically.

# Reachable hostname or IP for the host machine. Used for API CORS appendage.
HLH_PUBLIC_HOST=localhost

# Host-published ports (canonical defaults; override in .env if needed)
HLH_PORT_API=9600
HLH_PORT_UI=9604

# `npm run dev` / Vite dev: proxy /api → this URL (defaults to http://127.0.0.1:9600)
# HLH_VITE_API_PROXY=http://localhost:9600

# Split UI only: FastAPI host:port (no http://). Overrides default derived from HLH_PUBLIC_HOST.
# HLH_API_UPSTREAM=localhost:9600

# Database (asyncpg accepts postgresql:// or postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://hlh:hlh@hlh_db:5432/hlh

# Inference: OpenAI-compatible chat completions endpoint (llama-swap, Ollama, etc.).
INFERENCE_URL=http://localhost:8080
# Default model id (must match what your inference endpoint serves).
DEFAULT_MODEL=

# Embeddings: OpenAI-compatible /embeddings endpoint (infinity-emb, etc.).
EMBEDDING_URL=http://localhost:7997
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker: optional. Uses flashrank (CPU) as a fallback when unset or unreachable.
RERANKER_URL=http://localhost:7998
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Web search is bundled — see the hlh_search sidecar in docker-compose.yml.
# SEARXNG_URL is set automatically by compose to http://hlh_search:8080; do not
# override here. Engine + safe-search settings live in Settings → Search.

# CORS — comma-separated extra origins. The API also auto-appends http://<HLH_PUBLIC_HOST>:9604.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:9604

# ─── Phase 1+2: bundled sidecars (chat + embed/rerank) ───────────────────────
# Compose profile gate. Include `bundled` to start hlh_chat + hlh_infer with
# the stack; omit (or use `external`) to skip all bundled sidecars entirely.
COMPOSE_PROFILES=bundled

# Path inside the hlh_chat container — must point at a file that exists in
# the shared hlh_models volume. The api's model_puller writes to
# /models/<role>/<tier>/<filename> on Pull. cpu-min default; bump the tier
# segment to match what you've pulled.
HLH_CHAT_MODEL_PATH=/models/chat/cpu-min/Qwen3-1.7B-Q8_0.gguf

# Internal port for hlh_chat. Not published on the host; reachable from
# hlh_api as http://hlh_chat:${HLH_CHAT_PORT}.
HLH_CHAT_PORT=9610

# GPU layer offload count for llama.cpp. 0 = CPU only. Bump for gpu-* tiers.
HLH_CHAT_NGL=0

# HuggingFace token for gated repos (MedGemma). Empty = no auth header sent;
# unauthenticated pulls of Qwen3 GGUFs still work. Required + license-accept
# at the HF page before MedGemma pulls succeed (puller surfaces a 401 with
# the license_url).
HF_TOKEN=

# ─── Phase 2: bundled embed + rerank sidecar ──────────────────────────────────
# Internal port for hlh_infer (infinity-emb). Not published on the host;
# reachable from hlh_api as http://hlh_infer:${HLH_INFER_PORT}.
# Serves /v1/embeddings (bge-m3, 1024-dim) and /rerank (bge-reranker-v2-m3).
HLH_INFER_PORT=9611
