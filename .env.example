# Copy to `.env` and adjust per machine (laptop / desktop / server). Compose loads this file automatically.

# --- Reachable hostname or IP (Tailscale / LAN, no scheme) ---
# Used as the default base for:
#   - Docker image build args (VITE_PUBLIC_* cross-links between Boolab / BooOps / 808notes)
#   - Split UI stack: nginx → API when BOOLAB_API_UPSTREAM is not set (same host as the UI)
#   - API CORS: adds http://<host>:9302–9304 unless already in FRONTEND_ORIGIN
BOOLAB_PUBLIC_HOST=100.101.41.16

# Optional: host-published ports (defaults: 9300 API, 9302 Boolab UI, 9303 BooOps, 9304 808notes)
# BOOLAB_PORT_API=9300
# BOOLAB_PORT_BOOLAB_UI=9302
# BOOLAB_PORT_BOOOPS=9303
# BOOLAB_PORT_808NOTES=9304

# `npm run dev` / Vite: proxy /api → this URL (scheme + host + port). Defaults to http://127.0.0.1:9300
# BOOLAB_VITE_API_PROXY=http://100.101.41.16:9300

# Split UI only: FastAPI host:port (no http://). Overrides the default derived from BOOLAB_PUBLIC_HOST.
# BOOLAB_API_UPSTREAM=100.101.41.16:9300

# Database (asyncpg accepts postgresql:// or postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://boolab:boolab@boolab_db:5432/boolab

# ChromaDB (internal Docker hostname)
CHROMA_HOST=boolab_chroma
CHROMA_PORT=8000

# Inference: chat goes through Bifrost (OpenAI-compatible) → llama-swap → llama.cpp.
OLLAMA_URL=http://100.114.205.53:8080
OLLAMACTL_URL=http://100.114.205.53:8700
OLLAMA_MODEL=llama-desktop/qwen3.5-27b
DEFAULT_MODEL=llama-desktop/qwen3.5-27b

# Embeddings: infinity-emb (OpenAI-compatible) on the Tesla P4 box, BAAI/bge-m3 (1024 dims).
EMBEDDING_URL=http://100.93.187.4:7997
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker: infinity-rerank on the same P4 box. flashrank stays as a CPU fallback.
RERANKER_URL=http://100.93.187.4:7998
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Web search
SEARXNG_URL=http://100.114.205.53:8888
# Optional: host path to searxng settings.yml so Settings → Search can sync engine toggles (leave unset for API-only prefs)
# SEARXNG_SETTINGS_YML=/etc/searxng/settings.yml

# BourBites context endpoint
BOURBITES_CONTEXT_URL=http://100.114.205.53:8600/context

# DubDrive file browser (optional token; Tailscale often fronts the service)
DUBDRIVE_URL=http://100.114.205.53:9200
DUBDRIVE_TOKEN=

# CORS — comma-separated extra origins (https, localhost, etc.). Boolab also appends http://BOOLAB_PUBLIC_HOST:9302–9304 when BOOLAB_PUBLIC_HOST is set.
FRONTEND_ORIGIN=https://booops.boogaardmusic.com,https://808notes.boogaardmusic.com,https://boolab.boogaardmusic.com,http://localhost:9302,http://localhost:9303,http://localhost:9304

# Auth: Authelia handles authentication upstream. The backend trusts every request as samkintop (owner).

# Override full SPA URLs at image build time (optional; normally derived from BOOLAB_PUBLIC_HOST)
# VITE_PUBLIC_BOOOPS_URL=http://100.101.41.16:9303
# VITE_PUBLIC_808NOTES_URL=http://100.101.41.16:9304
# VITE_PUBLIC_BOOLAB_URL=http://100.101.41.16:9302
#
# Open Graph / Twitter use absolute URLs built in `frontend/.env.<mode>` from these (see frontend/index.html comment).
