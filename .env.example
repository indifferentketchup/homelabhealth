# Database (asyncpg accepts postgresql:// or postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://boolab:boolab@boolab_db:5432/boolab

# ChromaDB (internal Docker hostname)
CHROMA_HOST=boolab_chroma
CHROMA_PORT=8000

# Ollama + embeddings
OLLAMA_URL=http://100.101.41.16:11434
OLLAMA_MODEL=qwen3.5:9b
DEFAULT_MODEL=qwen3.5:9b
EMBEDDING_MODEL=qwen3-embedding:latest

# Web search
SEARXNG_URL=http://100.114.205.53:8888
# Optional: host path to searxng settings.yml so Settings → Search can sync engine toggles (leave unset for API-only prefs)
# SEARXNG_SETTINGS_YML=/etc/searxng/settings.yml

# Claude (optional until Phase 1+)
ANTHROPIC_API_KEY=

# BourBites context endpoint
BOURBITES_CONTEXT_URL=http://100.114.205.53:8600/context

# CORS — comma-separated origins for the SPA (every UI origin you use: local, Tailscale IP, prod domains)
FRONTEND_ORIGIN=https://booops.boogaardmusic.com,https://808notes.boogaardmusic.com,https://boolab.boogaardmusic.com,http://localhost:9302,http://localhost:9303,http://localhost:9304,http://100.72.117.26:9302,http://100.72.117.26:9303,http://100.72.117.26:9304

# Optional: override Vite public URLs at build time (docker-compose defaults: Tailscale IP + ports 9302/9303/9304)
# VITE_PUBLIC_BOOOPS_URL=http://100.72.117.26:9303
# VITE_PUBLIC_808NOTES_URL=http://100.72.117.26:9304
# VITE_PUBLIC_BOOLAB_URL=http://100.72.117.26:9302

# UI nginx → API (host:port only, no http://). Must be the FastAPI service (compose maps API :9300→8000), never UI ports 9302–9304.
# All-in-one compose defaults to boolab_api:8000. Split UI stack defaults to host.docker.internal:9300.
# Example (API on same machine via Tailscale): BOOLAB_API_UPSTREAM=100.72.117.26:9300
