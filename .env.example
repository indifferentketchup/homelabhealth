# Copy to `.env` and adjust per machine. Compose loads this file automatically.

# ─── Network ─────────────────────────────────────────────────────────────────
# Hostname or IP for CORS. Defaults to localhost (fine for local use).
HLH_PUBLIC_HOST=localhost

# Host-published ports.
HLH_PORT_API=9600
HLH_PORT_UI=9604

# CORS origins (comma-separated). API also auto-appends http://<HLH_PUBLIC_HOST>:9604.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:9604

# ─── Compose profiles ────────────────────────────────────────────────────────
# Which sidecars to start. Auto-set by the tier picker.
#   CPU tiers: bundled       GPU tiers: bundled-gpu
COMPOSE_PROFILES=bundled

# ─── Chat sidecar ────────────────────────────────────────────────────────────
# Internal port (not published to host).
HLH_CHAT_PORT=9610

# Memory limit. Adjust per tier:
#   cpu-min: 3g  cpu-std: 7g  gpu-4gb: 7g  gpu-8gb: 8g  gpu-16gb: 18g  gpu-24gb+: 24g
HLH_CHAT_MEM=7g

# ─── Vision lifecycle ────────────────────────────────────────────────────────
# Shared secret between hlh_api and hlh_orchestra.
# Leave empty: auto-generated on first boot. Only needed with vision profile.
ORCHESTRA_TOKEN=

# ─── Advanced (most operators leave these alone) ─────────────────────────────
# Container registry. Defaults to ghcr.io/indifferentketchup in compose.
# HLH_REGISTRY=ghcr.io/indifferentketchup
# HLH_VERSION=latest

# Docker image overrides (auto-set by tier picker).
# HLH_CHAT_IMAGE=ghcr.io/ggml-org/llama.cpp:server-b9282
# HLH_INFER_IMAGE=michaelf34/infinity:0.0.77-cpu
# HLH_MODELS_MAX=2
